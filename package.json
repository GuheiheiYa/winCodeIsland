{
  "name": "vibe-notch",
  "version": "1.0.0",
  "description": "Claude Code terminal session monitor - Dynamic Island for Windows",
  "main": "./out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && node -e \"require('fs').cpSync('electron/scripts', 'out/main/scripts', {recursive:true})\"",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@vicons/ionicons5": "^0.12.0",
    "@vicons/material": "^0.12.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.0"
  },
  "dependencies": {
    "marked": "^18.0.4",
    "node-pty": "^1.1.0",
    "pinia": "^2.1.0",
    "strip-ansi": "^7.2.0"
  },
  "keywords": [
    "electron",
    "vue",
    "dynamic-island",
    "claude-code",
    "terminal-monitor"
  ],
  "author": "VibeNotch Team",
  "license": "MIT"
}
