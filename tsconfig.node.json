{
  "compilerOptions": {
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@electron/*": ["electron/*"]
    },
    "types": ["electron-vite/node"]
  },
  "include": ["electron/**/*.ts", "src/types/**/*.ts", "*.config.ts"]
}
